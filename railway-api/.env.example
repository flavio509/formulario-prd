# ─── prd-api (Railway) — Variáveis de Ambiente ────────────────────────────────
# Configure estas variáveis no painel Railway → Variables.
# NUNCA commite valores reais no git.

# Anthropic — mesma chave usada na Vercel
ANTHROPIC_API_KEY=sk-ant-...

# Token de autenticação — chamadas browser → API (rota /gerar-prd)
# Deve ser idêntico ao NEXT_PUBLIC_GERAR_PRD_TOKEN na Vercel
API_TOKEN=COLE_O_TOKEN_AQUI

# Token de validação das chamadas server-to-server (proxy Vercel → API)
# Deve ser idêntico ao GERAR_PRD_TOKEN nas env vars da Vercel
GERAR_PRD_TOKEN=COLE_O_TOKEN_AQUI

# PORT é injetado automaticamente pelo Railway — não precisa definir aqui
# PORT=3001

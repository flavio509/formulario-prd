# ─── prd-api — Variáveis de Ambiente ──────────────────────────────────────────
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o .env no git.

# Anthropic — mesma chave usada na Vercel
ANTHROPIC_API_KEY=sk-ant-...

# Token de autenticação — deve ser idêntico ao NEXT_PUBLIC_GERAR_PRD_TOKEN na Vercel
# Gerado automaticamente durante o setup (40 chars hex aleatório)
API_TOKEN=COLE_O_TOKEN_AQUI

# Porta interna (Caddy faz o proxy HTTPS → esta porta)
PORT=3001
